<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="#1565C0"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥛"
                android:textSize="48sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Milk Entry"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- FORM CARD -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#FFFFFF">

                <!-- Milk Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Milk Type"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="6dp"/>

                <Spinner
                    android:id="@+id/milkType"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Member Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Member Name"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/memberName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Member name"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="16sp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="16dp"/>

                <!-- Litres -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Litres"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/litres"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Enter litres"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="16sp"
                    android:inputType="numberDecimal"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="16dp"/>

                <!-- Fat -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fat (optional)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/fat"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Enter fat %"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="16sp"
                    android:inputType="numberDecimal"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="16dp"/>

                <!-- Rate -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rate (₹ per litre)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/rate"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Enter rate"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="16sp"
                    android:inputType="numberDecimal"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="24dp"/>

                <!-- Save Button -->
                <Button
                    android:id="@+id/calcBtn"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="💾 Save Entry"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#1565C0"
                    android:textColor="#FFFFFF"/>

                <!-- Result -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:id="@+id/resultCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp">

                    <TextView
                        android:id="@+id/result"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:background="#E8F5E9"
                        android:gravity="center"
                        android:text="Amount will appear here"/>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>