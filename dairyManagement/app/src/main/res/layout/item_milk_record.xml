<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <!-- GREEN TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2E7D32"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/recordName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Member Name"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/recordDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026-04-29"
                android:textColor="#C8E6C9"
                android:textSize="12sp"/>

        </LinearLayout>

        <!-- DETAILS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <!-- LEFT: Litres + Fat -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Litres"
                    android:textSize="11sp"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/recordLitres"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 L"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fat"
                    android:textSize="11sp"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/recordFat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"/>

            </LinearLayout>

            <!-- DIVIDER -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#E0E0E0"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>

            <!-- RIGHT: Type + Amount -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/recordType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buffalo"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:background="#6A1B9A"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Amount"
                    android:textSize="11sp"
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/recordAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 0.00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"/>

            </LinearLayout>

        </LinearLayout>

        <!-- BOTTOM HINT -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✏️ Tap to edit or delete"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:paddingBottom="8dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>